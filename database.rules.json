{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider == 'anonymous'",
        ".write": "auth != null && auth.token.firebase.sign_in_provider == 'anonymous'",
        "answers": {
          "$cardId": {
            ".validate": "newData.hasChildren(['answer', 'question']) && newData.child('answer').isString() && newData.child('question').isString() && (!newData.hasChild('type') || newData.child('type').isString())"
          }
        },
        "skipped": {
          "$cardId": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "email": {
          ".validate": "newData.isString()"
        },
        "emailKey": {
          ".validate": "newData.isString()"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "activeRelationshipId": {
          ".validate": "newData.isString()"
        },
        "relationships": {
          "$relationshipId": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        }
      }
    },
    "relationships": {
      "$relationshipId": {
        ".read": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
        ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (!data.exists() && newData.child('members').child(auth.uid).child('role').val() == 'owner' || data.exists() && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists())",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "createdBy": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "members": {
          "$memberUid": {
            ".read": "auth != null && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
            ".write": "auth != null && (auth.uid == $memberUid || root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists())",
            "email": {
              ".validate": "newData.isString()"
            },
            "displayName": {
              ".validate": "newData.isString() && newData.val().length <= 80"
            },
            "role": {
              ".validate": "newData.isString() && (newData.val() == 'owner' || newData.val() == 'member')"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "invites": {
          "$emailKey": {
            ".read": "auth != null && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
            ".write": "auth != null && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()"
          }
        },
        "answers": {
          "$cardId": {
            "$memberUid": {
              ".read": "auth != null && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
              ".write": "auth != null && auth.uid == $memberUid && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
              ".validate": "newData.hasChildren(['answer', 'question']) && newData.child('answer').isString() && newData.child('question').isString() && (!newData.hasChild('type') || newData.child('type').isString())"
            }
          }
        },
        "skipped": {
          "$cardId": {
            "$memberUid": {
              ".read": "auth != null && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
              ".write": "auth != null && auth.uid == $memberUid && root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists()",
              ".validate": "newData.isBoolean() && newData.val() === true"
            }
          }
        }
      }
    },
    "invitesByEmail": {
      "$emailKey": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('emailKey').val() == $emailKey",
        "$relationshipId": {
          ".write": "auth != null && (root.child('relationships').child($relationshipId).child('members').child(auth.uid).exists() || !data.exists() && newData.child('invitedBy').val() == auth.uid)"
        }
      }
    }
  }
}
